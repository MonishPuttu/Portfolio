# ── Server ──────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database (Neon PostgreSQL) ──────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── CORS ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Cloudinary (Video Hosting) ─────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional: used only for organization/conventions when uploading manually
CLOUDINARY_UPLOAD_FOLDER=portfolio/projects
# Optional: root namespace ownership guard (defaults to first segment of CLOUDINARY_UPLOAD_FOLDER)
CLOUDINARY_ALLOWED_ROOT=portfolio
# Optional: set to false to skip Cloudinary existence checks before saving
CLOUDINARY_VERIFY_ASSET_EXISTENCE=true
# Optional: fallback thumbnail path when media cannot be resolved
CLOUDINARY_FALLBACK_THUMBNAIL=/fallback-thumbnail.png
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>
# ── JWT Auth ────────────────────────────────────
JWT_SECRET=your-strong-random-secret-min-32-chars
ADMIN_USERNAME=admin
# Generate with: node -e "import('bcryptjs').then(b=>b.default.hash('yourpassword',12).then(console.log))"
ADMIN_PASSWORD_HASH=$2a$12$...your-bcrypt-hash...

# ── Email (SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=your-admin-email@gmail.com
